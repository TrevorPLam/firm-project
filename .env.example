# Environment Variables Example
# Copy this file to .env.local and fill in the actual values
# DO NOT commit .env.local or any files with real secrets

# Site URL (for metadataBase in root layout)
# Used to resolve relative metadata URLs (Open Graph images, canonical URLs, etc.)
# Production: Set to your production domain (e.g., https://elevatedigital.com)
# Staging/Preview: Set to your staging domain
# Local Development: Can be omitted; defaults to https://elevatedigital.com
NEXT_PUBLIC_SITE_URL=https://elevatedigital.com

# Google Analytics 4 Measurement ID
# Get this from: https://analytics.google.com/ > Admin > Data Streams > Web
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Google Ads Conversion Tracking
# Get these from: https://ads.google.com/ > Tools & Settings > Conversions
# NEXT_PUBLIC_GA_CONVERSION_ID=AW-XXXXXXXXXX
# NEXT_PUBLIC_GA_CONVERSION_LABEL=conversion_label

# Optional: Other analytics services (currently not used)
# NEXT_PUBLIC_HOTJAR_ID=XXXXXX
# NEXT_PUBLIC_SENTRY_DSN=your_sentry_dsn

# Email Service (Resend)
# Get your API key from: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# Contact Form Destination Email
# Email address where contact form submissions will be sent
# CONTACT_EMAIL_TO=contact@elevatedigital.com

# Newsletter Audience ID (Resend)
# Get your audience ID from: https://resend.com/audiences
# Used to add subscribers to your newsletter list
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Upstash Redis (Rate Limiting)
# Get your credentials from: https://console.upstash.com/
# Used for production-ready rate limiting in serverless environments
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token
