# Environment Variables Example
# Copy this file to .env.local and fill in the actual values
# DO NOT commit .env.local or any files with real secrets
#
# Validation: This project uses a Zod-based validation module (app/lib/env.ts)
# to ensure type safety and fail-fast validation of environment variables.
# Required variables will throw errors if missing in production.
# Optional marketing integrations don't block local development.

# Site URL (for metadataBase in root layout)
# Used to resolve relative metadata URLs (Open Graph images, canonical URLs, etc.)
# Production: Set to your production domain (e.g., https://elevatedigital.com)
# Staging/Preview: Set to your staging domain
# Local Development: Can be omitted; defaults to https://elevatedigital.com
NEXT_PUBLIC_SITE_URL=https://elevatedigital.com

# Search Engine Indexing Control
# Controls whether search engines are allowed to index the site via robots.txt
# On Vercel: Only allows indexing when VERCEL_ENV=production (not preview)
# On other platforms: Allows indexing when NODE_ENV=production
# Set to "true" to force allow indexing (overrides environment detection)
# Set to "false" to force deny indexing (overrides environment detection)
# If unset: Uses environment detection (Vercel production or NODE_ENV=production)
# ALLOW_INDEXING=true

# Google Analytics 4 Measurement ID
# Get this from: https://analytics.google.com/ > Admin > Data Streams > Web
# Format: G-XXXXXXXXXX
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Optional: Google Ads Conversion Tracking
# Get these from: https://ads.google.com/ > Tools & Settings > Conversions
# NEXT_PUBLIC_GA_CONVERSION_ID=AW-XXXXXXXXXX
# NEXT_PUBLIC_GA_CONVERSION_LABEL=conversion_label


# Email Service (Resend)
# Get your API key from: https://resend.com/api-keys
# RESEND_API_KEY=re_xxxxxxxxxxxxx

# Contact Form Destination Email
# Email address where contact form submissions will be sent
# CONTACT_EMAIL_TO=contact@elevatedigital.com

# Newsletter Audience ID (Resend)
# Get your audience ID from: https://resend.com/audiences
# Used to add subscribers to your newsletter list
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Upstash Redis (Rate Limiting)
# Get your credentials from: https://console.upstash.com/
# Used for production-ready rate limiting in serverless environments
# UPSTASH_REDIS_REST_URL=https://your-redis-url.upstash.io
# UPSTASH_REDIS_REST_TOKEN=your-redis-token

# Algolia Search
# Get your credentials from: https://www.algolia.com/account/api-keys
# Used for site search functionality
# NEXT_PUBLIC_ALGOLIA_APPLICATION_ID=your_application_id
# NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY=your_search_api_key
# NEXT_PUBLIC_ALGOLIA_INDEX_NAME=content

# Sanity CMS
# Get your credentials from: https://www.sanity.io/manage
# Used for headless content management
# NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_READ_TOKEN=your_api_read_token
# SANITY_REVALIDATE_SECRET=your_webhook_secret

# React Compiler (Next.js 16)
# Enables automatic memoization of components and hooks
# WARNING: Currently causes build failure (vips_tracked: out of memory) on opengraph-image generation
# Keep disabled until the memory issue is resolved
# ENABLE_REACT_COMPILER=false
